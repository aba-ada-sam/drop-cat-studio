# Generated output — can be large
output/
uploads/
logs/
projects/

# Runtime config (may contain API keys / local paths)
config.json
keys.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
env/
venv-upscale/

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini

# Local SQLite stores (auto-created on boot)
*.db

# Chosen port + PID — written at server startup, consumed by launchers / tray
.dcs-port
.dcs-port.tmp

# Node / Electron
node_modules/
.npm/

# Local planning / scratch notes (not part of shipped docs)
RESTART_ME.txt
DIAGNOSE_FORGE.md
FORGE_REDESIGN_ANALYSIS.md
REDESIGN_INSPIRATION.md
REVIEW.md
UI_REFACTOR_SUMMARY.md
UX_PLAN.md
OPEN_CLAW_MACHINE_CAPABILITIES.md
dcs-laptop-setup.zip

# Session scratch + diagnostics, repo root only.
# Anchored with a leading slash so tracked files like features/*/__init__.py
# and features/lipsync/_demucs_separate.py are never matched.
/_*.png
/_*.py
/_*.sh
/_*.patch
/_*.log
/_*.txt
/_*.md
/_cdp_profile*/
/.chrome_profile/
/.claude/worktrees/
/.claude/scheduled_tasks.lock
/stdout.txt
/stderr.txt
/dcs-stdout.log
/dcs-stderr.log
/manager_diag.txt
/manager_stdout.txt
/manager_stderr.txt
/mutex_test*.txt
/status_check.txt
/null
/logsapp_restart.log
/FIRST_PROMPT.txt
/OVERNIGHT_NOTES_*.md

# Local operator scripts. They carry this machine's absolute paths (and a LAN IP
# in setup_satellite.py), so they stay on disk and out of the repo.
/open_dcs.ps1
/restart_dcs.ps1
/overnight_art.ps1
/overnight_orchestrator.ps1
/tools/screenshot.ps1
/tools/setup_satellite.py

# dropcat_output.ico is the icon for the Desktop "DropCat Output" shortcut --
# it lives here on purpose. Ignore it rather than committing a binary.
/dropcat_output.ico

# Generated artifacts: screenshot.ps1's output, icon previews, extracted QC frames.
/tools/screenshot.png
/tools/icon_*preview*.png
/tools/review_frames/
/tools/slop*/

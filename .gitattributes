# Normalize line endings — stops Windows/Unix CRLF warnings on every commit.
* text=auto eol=lf

# Explicit binary so git never tries to munge them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.wav binary
*.db binary
*.pdf binary

# Windows-only scripts — keep CRLF so they run natively.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.vbs text eol=crlf
